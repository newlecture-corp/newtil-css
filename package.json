{
	"name": "@newtil/css",
	"version": "0.5.1",
	"description": "Tailwind 대체재 — 실제 CSS 속성명/축약 기반 utility class. @newtil/design-tokens 위에 동작",
	"publishConfig": {
		"access": "public"
	},
	"main": "./dist/style.css",
	"style": "./dist/style.css",
	"type": "module",
	"exports": {
		".": "./dist/style.css",
		"./style.css": "./dist/style.css",
		"./utils.css": "./dist/utils.css",
		"./reset.css": "./dist/reset.css",
		"./jit/postcss-plugin": {
			"import": "./jit/postcss-plugin.js",
			"require": "./jit/postcss-plugin.cjs"
		},
		"./jit/postcss-plugin.js": {
			"import": "./jit/postcss-plugin.js",
			"require": "./jit/postcss-plugin.cjs"
		},
		"./jit/vite-plugin.js": "./jit/vite-plugin.js",
		"./jit/jit.js": "./jit/jit.js",
		"./package.json": "./package.json"
	},
	"keywords": [
		"css",
		"utility css",
		"util css",
		"tailwind alternative",
		"design system"
	],
	"author": "lectureteam",
	"license": "MIT",
	"scripts": {
		"generate": "node generator/generate.js",
		"build": "npm run generate && rm -rf ./dist && rollup -c",
		"deploy": "npm run build && npm publish",
		"prepublishOnly": "npm run build",
		"docs:dev": "vitepress dev docs --host",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs"
	},
	"dependencies": {
		"@newtil/design-tokens": "^0.2.0"
	},
	"devDependencies": {
		"@newtil/components": "^0.1.0",
		"postcss": "^8.4.33",
		"postcss-import": "^16.1.0",
		"rollup": "^4.52.5",
		"rollup-plugin-postcss": "^4.0.2",
		"vitepress": "^1.6.4"
	},
	"directories": {
		"doc": "docs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/newlecture-corp/newtil-css.git"
	},
	"bugs": {
		"url": "https://github.com/newlecture-corp/newtil-css/issues"
	},
	"homepage": "https://github.com/newlecture-corp/newtil-css#readme",
	"files": [
		"dist",
		"jit",
		"generator",
		"README.md",
		"LICENSE",
		"MIGRATION.md"
	]
}
